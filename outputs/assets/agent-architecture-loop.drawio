<mxfile host="app.diagrams.net" modified="2026-04-16" agent="book-project" version="24.0.0" type="device">
  <diagram id="agent-architecture-loop" name="Agent Architecture Loop">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="The Agent Architecture Loop" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- Subtitle -->
        <mxCell id="subtitle" value="The universal pattern shared by human agents, classical software agents, and modern AI agents" style="text;html=1;fontSize=12;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="250" y="55" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- PERCEIVE box -->
        <mxCell id="perceive" value="PERCEIVE" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontFamily=Helvetica;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="110" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="perceive_desc" value="Gather information from the environment" style="text;html=1;fontSize=11;align=center;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#4a6fa5;" vertex="1" parent="1">
          <mxGeometry x="440" y="175" width="220" height="25" as="geometry" />
        </mxCell>

        <!-- REASON box -->
        <mxCell id="reason" value="REASON" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontFamily=Helvetica;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="280" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reason_desc" value="Process, decide, update internal state" style="text;html=1;fontSize=11;align=center;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#5a8a5a;" vertex="1" parent="1">
          <mxGeometry x="720" y="345" width="220" height="25" as="geometry" />
        </mxCell>

        <!-- ACT box -->
        <mxCell id="act" value="ACT" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontFamily=Helvetica;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="450" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="act_desc" value="Execute the chosen action" style="text;html=1;fontSize=11;align=center;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#8a7a3a;" vertex="1" parent="1">
          <mxGeometry x="440" y="515" width="220" height="25" as="geometry" />
        </mxCell>

        <!-- LEARN box -->
        <mxCell id="learn" value="LEARN" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontFamily=Helvetica;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="280" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="learn_desc" value="Observe outcome, update future behavior" style="text;html=1;fontSize=11;align=center;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#6a4a7a;" vertex="1" parent="1">
          <mxGeometry x="160" y="345" width="220" height="25" as="geometry" />
        </mxCell>

        <!-- Arrow: PERCEIVE → REASON -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#4a4a6a;endArrow=blockThin;endFill=1;endSize=8;" edge="1" parent="1" source="perceive" target="reason">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: REASON → ACT -->
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#4a4a6a;endArrow=blockThin;endFill=1;endSize=8;" edge="1" parent="1" source="reason" target="act">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: ACT → LEARN -->
        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#4a4a6a;endArrow=blockThin;endFill=1;endSize=8;" edge="1" parent="1" source="act" target="learn">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: LEARN → PERCEIVE -->
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#4a4a6a;endArrow=blockThin;endFill=1;endSize=8;" edge="1" parent="1" source="learn" target="perceive">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ENVIRONMENT cloud -->
        <mxCell id="env" value="ENVIRONMENT" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=2;fontFamily=Helvetica;fontColor=#666666;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="255" width="260" height="130" as="geometry" />
        </mxCell>

        <!-- Dashed lines from environment -->
        <mxCell id="env_to_perceive" style="edgeStyle=none;dashed=1;dashPattern=8 4;strokeWidth=1.5;strokeColor=#999999;endArrow=open;endFill=0;endSize=6;" edge="1" parent="1" source="env" target="perceive">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="act_to_env" style="edgeStyle=none;dashed=1;dashPattern=8 4;strokeWidth=1.5;strokeColor=#999999;endArrow=open;endFill=0;endSize=6;" edge="1" parent="1" source="act" target="env">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Human agent column -->
        <mxCell id="human_header" value="Human Agent" style="text;html=1;fontSize=13;fontStyle=5;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="50" y="555" width="150" height="25" as="geometry" />
        </mxCell>
        <mxCell id="human_perceive" value="&lt;b&gt;Perceive:&lt;/b&gt; Read emails, listen in meetings, observe the factory floor" style="text;html=1;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#4a6fa5;" vertex="1" parent="1">
          <mxGeometry x="50" y="580" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="human_reason" value="&lt;b&gt;Reason:&lt;/b&gt; Weigh options, apply experience, exercise judgment" style="text;html=1;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#5a8a5a;" vertex="1" parent="1">
          <mxGeometry x="50" y="600" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="human_act" value="&lt;b&gt;Act:&lt;/b&gt; Write code, make a sales call, send a proposal" style="text;html=1;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#8a7a3a;" vertex="1" parent="1">
          <mxGeometry x="50" y="620" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="human_learn" value="&lt;b&gt;Learn:&lt;/b&gt; Adjust approach after feedback, improve over time" style="text;html=1;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#6a4a7a;" vertex="1" parent="1">
          <mxGeometry x="50" y="640" width="300" height="20" as="geometry" />
        </mxCell>

        <!-- AI agent column -->
        <mxCell id="ai_header" value="AI Agent" style="text;html=1;fontSize=13;fontStyle=5;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="700" y="555" width="150" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ai_perceive" value="&lt;b&gt;Perceive:&lt;/b&gt; Receive input, retrieve context, read tool outputs" style="text;html=1;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#4a6fa5;" vertex="1" parent="1">
          <mxGeometry x="700" y="580" width="330" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ai_reason" value="&lt;b&gt;Reason:&lt;/b&gt; LLM inference, chain-of-thought, planning" style="text;html=1;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#5a8a5a;" vertex="1" parent="1">
          <mxGeometry x="700" y="600" width="330" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ai_act" value="&lt;b&gt;Act:&lt;/b&gt; Call tools, execute code, generate responses" style="text;html=1;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#8a7a3a;" vertex="1" parent="1">
          <mxGeometry x="700" y="620" width="330" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ai_learn" value="&lt;b&gt;Learn:&lt;/b&gt; Observe results, update memory, refine via feedback" style="text;html=1;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#6a4a7a;" vertex="1" parent="1">
          <mxGeometry x="700" y="640" width="330" height="20" as="geometry" />
        </mxCell>

        <!-- Divider line -->
        <mxCell id="divider" value="" style="endArrow=none;dashed=1;dashPattern=4 4;strokeColor=#cccccc;strokeWidth=1;" edge="1" parent="1">
