<mxfile host="app.diagrams.net" modified="2026-04-19" agent="book-project" version="24.0.0" type="device">
  <diagram id="company-architecture" name="Architecture of a Company">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="750" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="The Architecture of a Company" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Five components. Each doing a specific job. Each wired into the others." style="text;html=1;fontSize=12;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="250" y="55" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- Outer boundary envelope -->
        <mxCell id="boundary_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673a6;strokeWidth=3;dashed=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="110" y="210" width="880" height="460" as="geometry" />
        </mxCell>
        <mxCell id="boundary_label" value="BOUNDARY  (legal + economic edge of the firm)" style="text;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#6a3d9a;fillColor=#ffffff;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="140" y="198" width="360" height="24" as="geometry" />
        </mxCell>

        <!-- DIRECTION (top, outside boundary - sets the goal) -->
        <mxCell id="direction" value="DIRECTION" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontFamily=Helvetica;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="100" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="direction_desc" value="Who you serve. What you promise. How you price. Where the margin comes from." style="text;html=1;fontSize=11;align=center;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#4a6fa5;" vertex="1" parent="1">
          <mxGeometry x="400" y="165" width="300" height="35" as="geometry" />
        </mxCell>

        <!-- CONTROL SYSTEM (top-inside boundary) -->
        <mxCell id="control" value="CONTROL SYSTEM" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontFamily=Helvetica;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="260" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="control_desc" value="Approvals, reporting lines, pricing rules, weekly reviews, decision rights" style="text;html=1;fontSize=11;align=center;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#8a6d1f;" vertex="1" parent="1">
          <mxGeometry x="400" y="325" width="300" height="35" as="geometry" />
        </mxCell>

        <!-- OPERATING ENGINE (middle-left) -->
        <mxCell id="operating" value="OPERATING ENGINE" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontFamily=Helvetica;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="170" y="420" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="operating_desc" value="Qualify → sell → build → deploy → support → invoice → collect" style="text;html=1;fontSize=11;align=center;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#4f7a4f;" vertex="1" parent="1">
          <mxGeometry x="160" y="485" width="300" height="35" as="geometry" />
        </mxCell>

        <!-- CAPABILITY ENGINE (middle-right) -->
        <mxCell id="capability" value="CAPABILITY ENGINE" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontFamily=Helvetica;arcSize=20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="420" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="capability_desc" value="Every cycle, the operating engine gets tighter, faster, smarter" style="text;html=1;fontSize=11;align=center;verticalAlign=top;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#8a3a38;" vertex="1" parent="1">
          <mxGeometry x="640" y="485" width="300" height="35" as="geometry" />
        </mxCell>

        <!-- Market (outside boundary, below) -->
        <mxCell id="market_in" value="Customers&#10;(value delivered →&#10;cash captured)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="200" y="690" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="market_out" value="Market&#10;(suppliers, tools, services&#10;rented from outside)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="680" y="690" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <!-- Direction sets goal for Control -->
        <mxCell id="arrow_dir_ctrl" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="direction" target="control">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_dir_ctrl_label" value="sets the goal" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#4a6fa5;" vertex="1" parent="1">
          <mxGeometry x="695" y="215" width="90" height="20" as="geometry" />
        </mxCell>

        <!-- Control → Operating -->
        <mxCell id="arrow_ctrl_op" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#d6b656;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="control" target="operating">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_ctrl_op_label" value="aligns" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#8a6d1f;" vertex="1" parent="1">
          <mxGeometry x="355" y="365" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- Control → Capability -->
        <mxCell id="arrow_ctrl_cap" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#d6b656;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="control" target="capability">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_ctrl_cap_label" value="aligns" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#8a6d1f;" vertex="1" parent="1">
          <mxGeometry x="685" y="365" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- Operating ↔ Capability (feedback loop) -->
        <mxCell id="arrow_op_cap" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#82b366;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.35;entryDx=0;entryDy=0;" edge="1" parent="1" source="operating" target="capability">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_op_cap_label" value="produces learnings" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#4f7a4f;fillColor=#ffffff;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="470" y="432" width="140" height="18" as="geometry" />
        </mxCell>

        <mxCell id="arrow_cap_op" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#b85450;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="capability" target="operating">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_cap_op_label" value="feeds back improvements" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#8a3a38;fillColor=#ffffff;strokeColor=none;align=center;" vertex="1" parent="1">
          <mxGeometry x="455" y="473" width="180" height="18" as="geometry" />
        </mxCell>

        <!-- Operating → Customers -->
        <mxCell id="arrow_op_cust" style="endArrow=classic;startArrow=classic;html=1;strokeWidth=2;strokeColor=#999999;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="operating" target="market_in">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_op_cust_label" value="value ↔ cash" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="315" y="600" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- Operating/Capability → Market -->
        <mxCell id="arrow_op_mkt" style="endArrow=classic;startArrow=classic;html=1;strokeWidth=2;strokeColor=#999999;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="capability" target="market_out">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_op_mkt_label" value="what you rent" style="text;html=1;fontSize=10;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="795" y="600" width="110" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
